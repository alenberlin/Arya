    "ai": "^7.0.14",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  }
}
