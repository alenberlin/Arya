# Arya API configuration. Provider keys live ONLY here, server-side.
# Copy to .env and fill in. In local/open-source mode a shared bearer token
# authenticates the desktop; in production, Clerk JWTs do.

# --- auth ---
# "local" (default): shared token below authenticates any request.
# "clerk": verify Clerk-issued RS256 JWTs against the instance JWKS.
ARYA_API_MODE=local
ARYA_API_LOCAL_TOKEN=local-dev-token
# CLERK_ISSUER=https://your-instance.clerk.accounts.dev
# CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
# CLERK_AUDIENCE=arya-api

# --- server ---
ARYA_API_BIND=127.0.0.1:8477
ARYA_API_DB=arya-api.db

# --- upstream provider keys (server-side only) ---
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
ARYA_OLLAMA_URL=http://127.0.0.1:11434
